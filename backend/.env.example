# Copy this file to .env and fill in your keys.
# Both providers have free tiers.

# Tavily — web search built for LLM pipelines. Sign up at https://tavily.com
TAVILY_API_KEY=your_key_here

# Groq — fast LLM inference (free tier). Sign up at https://console.groq.com
GROQ_API_KEY=your_key_here

# Comma-separated list of frontend origins allowed to call this API (CORS).
# Local dev defaults to http://localhost:3000 if unset. In production, set this
# to your deployed frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
